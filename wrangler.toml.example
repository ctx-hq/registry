name = "ctx-registry"
main = "src/index.ts"
compatibility_date = "2025-03-27"
compatibility_flags = ["nodejs_compat"]

routes = [
  { pattern = "registry.getctx.org", custom_domain = true }
]

[[d1_databases]]
binding = "DB"
database_name = "ctx-registry"
database_id = "<your-d1-database-id>"
migrations_dir = "migrations"

[[r2_buckets]]
binding = "FORMULAS"
bucket_name = "ctx-formulas"

[[kv_namespaces]]
binding = "CACHE"
id = "<your-kv-namespace-id>"

[[vectorize]]
binding = "VECTORIZE"
index_name = "ctx-packages"

[ai]
binding = "AI"

[[queues.producers]]
binding = "ENRICHMENT_QUEUE"
queue = "ctx-enrichment"

[[queues.consumers]]
queue = "ctx-enrichment"
max_batch_size = 10
max_batch_timeout = 30

[vars]
GITHUB_CLIENT_ID = ""

# Secrets (set via `wrangler secret put`):
#   GITHUB_CLIENT_SECRET

# Cron trigger for scanner (requires available cron slot, limit: 5 per account)
# [triggers]
# crons = ["0 */6 * * *"]

# ── Staging environment ──────────────────────────────────────
# Deploy: wrangler deploy --env staging
# Migrate: wrangler d1 migrations apply ctx-staging --env staging --remote
[env.staging]
name = "ctx-registry-staging"

[[env.staging.d1_databases]]
binding = "DB"
database_name = "ctx-staging"
database_id = "<your-staging-d1-id>"
migrations_dir = "migrations"

[[env.staging.r2_buckets]]
binding = "FORMULAS"
bucket_name = "ctx-formulas-staging"

[[env.staging.kv_namespaces]]
binding = "CACHE"
id = "<your-staging-kv-id>"

# VECTORIZE, AI, ENRICHMENT_QUEUE intentionally omitted for staging
# Add them if staging needs search, enrichment, or embedding features

[env.staging.vars]
GITHUB_CLIENT_ID = ""
