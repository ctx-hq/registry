{
  "name": "ctx-web",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply ctx-registry --local",
    "e2e": "vitest run --config e2e/vitest.config.ts",
    "e2e:reset": "bash e2e/reset.sh",
    "e2e:setup": "pnpm e2e:reset && pnpm e2e",
    "staging:deploy": "wrangler deploy --env staging",
    "staging:migrate": "wrangler d1 migrations apply ctx-staging --env staging --remote"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250327.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "~3.1.0",
    "wrangler": "^4.14.0"
  }
}
