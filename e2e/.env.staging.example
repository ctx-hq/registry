# E2E staging environment — copy to .env.staging and fill in values.
# DO NOT commit .env.staging to git.

# Staging API URL (from wrangler deploy --env staging output)
STAGING_API_URL=https://ctx-api-staging.<your-subdomain>.workers.dev

# Pre-seeded test tokens (must match hashes in seed.sql)
E2E_ALICE_TOKEN=ctx_e2e_alice_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
E2E_BOB_TOKEN=ctx_e2e_bob_bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
